# 通义千问 API Key（必需）
DASHSCOPE_API_KEY=sk-your-api-key-here

# Milvus 连接
MILVUS_HOST=localhost
MILVUS_PORT=19530

# PostgreSQL + Redis
DATABASE_URL=postgresql+asyncpg://rag:rag123@localhost:5432/rag_platform
REDIS_URL=redis://localhost:6379/0

# 模型配置
DASHSCOPE_MODEL=qwen-turbo-latest
DASHSCOPE_VL_MODEL=qwen-vl-plus
CLIP_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
OCR_LANG=ch

# 视频处理
MAX_VIDEO_SIZE_MB=500
VIDEO_FPS=2.0
VIDEO_KEY_FRAMES=10
VIDEO_UNDERSTAND_MODEL=qwen-vl-max
T2V_MODEL=wanx2.1-t2v-turbo

# 应用参数
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
UPLOAD_DIR=uploads
FRAMES_DIR=uploads/frames

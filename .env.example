# 通义千问 API Key（必需）
DASHSCOPE_API_KEY=sk-your-api-key-here

# Milvus 连接
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 模型配置
DASHSCOPE_MODEL=qwen-turbo-latest
CLIP_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
OCR_LANG=ch

# 应用参数
MAX_UPLOAD_SIZE_MB=500
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
UPLOAD_DIR=uploads
